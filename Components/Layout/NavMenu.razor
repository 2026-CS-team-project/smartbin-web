@rendermode InteractiveServer
@implements IDisposable
@inject SmartBin.Services.AlertService AlertService

<div class="sidebar-inner">
    <div class="brand">
        <div class="brand-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 6h18" /><path d="M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2" />
                <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6" />
                <path d="M10 11v6" /><path d="M14 11v6" />
            </svg>
        </div>
        <div class="brand-text">
            <div class="brand-title">SmartBin</div>
            <div class="brand-sub">스마트 도심 쓰레기통 관리</div>
        </div>
    </div>

    <input type="checkbox" title="Navigation menu" class="navbar-toggler" />

    <nav class="nav-list">
        <NavLink class="nav-item" href="" Match="NavLinkMatch.All">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="3" width="7" height="9" rx="1.5" />
                <rect x="14" y="3" width="7" height="5" rx="1.5" />
                <rect x="14" y="12" width="7" height="9" rx="1.5" />
                <rect x="3" y="16" width="7" height="5" rx="1.5" />
            </svg>
            <span>대시보드</span>
        </NavLink>

        <NavLink class="nav-item" href="bins">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 1 1 18 0z" />
                <circle cx="12" cy="10" r="3" />
            </svg>
            <span>쓰레기통 관리</span>
        </NavLink>

        <NavLink class="nav-item" href="trucks">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M1 7h13v10H1z" /><path d="M14 10h4l3 3v4h-7z" />
                <circle cx="5.5" cy="18.5" r="2" /><circle cx="17.5" cy="18.5" r="2" />
            </svg>
            <span>수거차 관리</span>
        </NavLink>

        <NavLink class="nav-item" href="alerts">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9" />
                <path d="M13.73 21a2 2 0 0 1-3.46 0" />
            </svg>
            <span>알림 센터</span>
            @if (AlertService.UnreadCount > 0)
            {
                <span class="nav-badge">@(AlertService.UnreadCount > 99 ? "99+" : AlertService.UnreadCount.ToString())</span>
            }
        </NavLink>
    </nav>

    <div class="sidebar-footer">
        <div class="user-avatar">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="8" r="4" />
                <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7" />
            </svg>
        </div>
        <div class="user-info">
            <div class="user-name">@user_name</div>
            <div class="user-role">@user_role</div>
        </div>
    </div>
</div>

@code {
    private string user_name = "홍길동";
    private string user_role = "시스템 관리자";

    protected override void OnInitialized()
    {
        AlertService.OnChanged += HandleChanged;
    }

    private void HandleChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        AlertService.OnChanged -= HandleChanged;
    }
}
