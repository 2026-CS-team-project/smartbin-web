@page "/alerts"
@rendermode InteractiveServer
@implements IDisposable
@inject SmartBin.Services.AlertService AlertService

<title>SmartBin - 알림 센터</title>

<div class="page-header">
    <div>
        <h1 class="page-title">알림 센터</h1>
        <div class="page-sub">쓰레기통 적재율 임계값(70% / 90%) 초과 알림</div>
    </div>
    @if (AlertService.UnreadCount > 0)
    {
        <div class="page-actions">
            <button class="btn-primary-soft" @onclick="AlertService.MarkAllRead">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="20 6 9 17 4 12" />
                </svg>
                모두 읽음 처리
            </button>
        </div>
    }
</div>

@{
    var alerts = AlertService.GetAlerts();
}

@if (!alerts.Any())
{
    <div class="alert-empty">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9" />
            <path d="M13.73 21a2 2 0 0 1-3.46 0" />
        </svg>
        <p>아직 발생한 알림이 없습니다.</p>
        <span>쓰레기통 적재율이 70% 또는 90%를 초과하면 여기에 표시됩니다.</span>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var alert in alerts)
        {
            <div class="col-12 col-lg-6">
                <div class="alert-card @(alert.Threshold >= 90 ? "danger" : "warn")">
                    <div class="alert-card-header">
                        <div class="alert-meta">
                            <span class="status @(alert.Threshold >= 90 ? "danger" : "warn")">
                                @(alert.Threshold >= 90 ? "긴급" : "주의")
                            </span>
                            <span class="bin-id">@alert.BinId</span>
                        </div>
                        <span class="alert-time">@alert.Timestamp.ToString("MM/dd HH:mm:ss")</span>
                    </div>
                    <div class="alert-msg">@alert.BinName — 적재율 @alert.FillLevel% 도달</div>
                    <div class="bin-meta">임계값 @alert.Threshold% 초과 감지</div>
                </div>
            </div>
        }
    </div>
}

@code {
    protected override void OnInitialized()
    {
        AlertService.OnChanged += HandleChanged;
    }

    private void HandleChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        AlertService.OnChanged -= HandleChanged;
    }
}
