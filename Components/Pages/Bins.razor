@page "/bins"
@rendermode InteractiveServer
@inject SmartBin.Services.BinService BinService

<PageTitle>쓰레기통 관리</PageTitle>

<h1 class="mb-3">쓰레기통 관리</h1>

@if (_loading)
{
    <p>불러오는 중...</p>
}
else
{
    <div class="row g-3">
        @foreach (var bin in _bins)
        {
            <div class="col-12 col-sm-6 col-lg-4 col-xl-3">
                <a class="bin-card" href="/bins/@Uri.EscapeDataString(bin.BinId)">
                    <div class="bin-card-header">
                        <span class="bin-id">@bin.BinId</span>
                        <span class="status @bin.StatusClass">@bin.StatusText</span>
                    </div>
                    <div class="bin-name">@bin.binName</div>
                    <div class="bin-meta">X: @bin.X.ToString("F1") / Y: @bin.Y.ToString("F1") / Z: @bin.Z.ToString("F1")</div>
                    <div class="fill-bar">
                        <div class="fill" style="width:@(bin.DisplayFillLevel)%"></div>
                    </div>
                    <div class="bin-meta">적재율 @(bin.DisplayFillLevel)% · @bin.UpdatedAt.ToLocalTime().ToString("HH:mm")</div>
                </a>
            </div>
        }
    </div>
}

@code {
    private List<SmartBin.Models.Bin> _bins = new();
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        _bins = await BinService.GetAllAsync();
        _loading = false;
    }
}
