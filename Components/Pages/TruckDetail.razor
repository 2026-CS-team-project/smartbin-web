        ["T-03"] = new("T-03", "박지훈", "송파 1권역", "서울 56다 1234", "현대 포터2",  2500,  0,  0, "—",     "대기중",  "대기",   "off", new()),
        ["T-04"] = new("T-04", "최유나", "송파 2권역", "서울 78라 5678", "현대 메가트럭", 5000, 61, 12, "BIN-006", "약 5분", "운행중", "ok",
            new() {
                new("BIN-006", "송파구 잠실동 잠실역",     77, "주의",    "warn", true),
