@page "/trucks/{Code}"

<PageTitle>수거차 @Code</PageTitle>

<div class="d-flex align-items-center gap-2 mb-3">
    <a href="trucks" class="back-link">← 목록</a>
    <h1 class="m-0">수거차 @Code 상세보기</h1>
    <span class="status @_truck.StatusClass ms-2">@_truck.Status</span>
</div>

<div class="row g-3 mb-3">
    <div class="col-6 col-md-3">
        <div class="stat-card">
            <div class="stat-icon icon-blue">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M1 7h13v10H1z" /><path d="M14 10h4l3 3v4h-7z" />
                    <circle cx="5.5" cy="18.5" r="2" /><circle cx="17.5" cy="18.5" r="2" />
                </svg>
            </div>
            <div>
                <div class="stat-label">현재 적재량</div>
                <div class="stat-value">@(_truck.Load)<span class="unit">%</span></div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card">
            <div class="stat-icon icon-green">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M3 6h18" /><path d="M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2" />
                    <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6" />
                </svg>
            </div>
            <div>
                <div class="stat-label">금일 수거 처리</div>
                <div class="stat-value">@(_truck.Done)<span class="unit">건</span></div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card">
            <div class="stat-icon icon-sky">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 1 1 18 0z" />
                    <circle cx="12" cy="10" r="3" />
                </svg>
            </div>
            <div>
                <div class="stat-label">현재 목적지</div>
                <div class="stat-value" style="font-size:1.1rem">@_truck.DestBin</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card">
            <div class="stat-icon icon-red">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10" />
                    <polyline points="12 6 12 12 16 14" />
                </svg>
            </div>
            <div>
                <div class="stat-label">도착 예정</div>
                <div class="stat-value" style="font-size:1.1rem">@_truck.Eta</div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-12 col-lg-5">
        <div class="panel">
            <h2 class="panel-title">기본 정보</h2>
            <dl class="info-list">
                <dt>차량 코드</dt><dd>@_truck.Code</dd>
                <dt>담당 기사</dt><dd>@(_truck.Driver) 기사</dd>
                <dt>담당 권역</dt><dd>@_truck.Area</dd>
                <dt>차량 번호</dt><dd>@_truck.PlateNo</dd>
                <dt>차량 모델</dt><dd>@_truck.Model</dd>
                <dt>최대 적재</dt><dd>@_truck.MaxLoad kg</dd>
            </dl>
        </div>
    </div>
    <div class="col-12 col-lg-7">
        <div class="panel">
            <h2 class="panel-title">수거 대기 목록</h2>
            <div class="route-list">
                @foreach (var (bin, idx) in _truck.Queue.Select((b, i) => (b, i + 1)))
                {
                    <div class="route-item @(bin.IsCurrent ? "current" : "")">
                        <div class="route-seq">@idx</div>
                        <div class="route-body">
                            <div class="route-bin">@bin.BinId <span class="bin-id ms-1">@bin.Location</span></div>
                            <div class="fill-bar mt-1">
                                <div class="fill @(bin.Fill >= 90 ? "fill-danger" : bin.Fill >= 70 ? "fill-warn" : "")" style="width:@(bin.Fill)%"></div>
                            </div>
                            <div class="bin-meta mt-1">적재율 @bin.Fill%</div>
                        </div>
                        <span class="status @bin.StatusClass">@bin.Status</span>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public string Code { get; set; } = "";

    private TruckInfo _truck = default!;

    private record QueueBin(string BinId, string Location, int Fill, string Status, string StatusClass, bool IsCurrent = false);

    private record TruckInfo(
        string Code, string Driver, string Area, string PlateNo, string Model,
        int MaxLoad, int Load, int Done,
        string DestBin, string Eta,
        string Status, string StatusClass,
        List<QueueBin> Queue);

    private static readonly Dictionary<string, TruckInfo> _data = new()
    {
        ["T-01"] = new("T-01", "김민수", "강남 1권역", "서울 12가 3456", "현대 메가트럭", 5000, 42, 18, "BIN-003", "약 8분", "운행중", "ok",
            new() {
