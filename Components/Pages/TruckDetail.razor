        ["T-05"] = new("T-05", "정도현", "서초 1권역", "서울 90마 9012", "기아 봉고3",  3500, 15,  5, "BIN-021", "약 12분", "운행중", "ok",
            new() {
                new("BIN-021", "서초구 서초동 교대역",     82, "주의",    "warn", true),
                new("BIN-025", "서초구 잠원동 한강진역",   48, "정상",    "ok"),
            }),
        ["T-06"] = new("T-06", "한지민", "서초 2권역", "서울 11바 3456", "현대 메가트럭", 5000, 95, 27, "차고지", "약 3분",  "긴급",   "danger",
            new() {
