@page "/"
@rendermode InteractiveServer
@inject SmartBin.Services.BinService BinService
@inject SmartBin.Services.TruckService TruckService

<title>SmartBin - 대시보드</title>

<div class="page-header">
    <div>
        <h1 class="page-title">도심 스마트 쓰레기통 현황</h1>
        <div class="page-sub">서브 타이틀: 강남구 일대 실시간 모니터링 중</div>
    </div>
</div>

<div class="map-card">
    <div class="map-placeholder">
        <div class="map-watermark">Unity WebGL 지도 영역</div>
        <div class="map-hint">빌드된 Unity 결과물 연결 필요</div>

        <div class="map-legend">
            <div><span class="dot ok"></span>비어있음 (0–30%)</div>
            <div><span class="dot warn"></span>수거 필요 (50–70%)</div>
            <div><span class="dot danger"></span>즉시 수거 필요 (90%)</div>
        </div>
    </div>
</div>

<div class="row g-3 mt-1">
    <div class="col-6 col-lg-3">
        <div class="stat-card">
            <div class="stat-icon icon-blue">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M3 6h18" /><path d="M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2" />
                    <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6" />
                </svg>
            </div>
            <div>
                <div class="stat-label">전체 쓰레기통 개수</div>
                <div class="stat-value">@_totalBins</div>
            </div>
        </div>
    </div>

    <div class="col-6 col-lg-3">
        <div class="stat-card">
            <div class="stat-icon icon-red">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10" /><path d="M12 8v4" /><path d="M12 16h.01" />
                </svg>
            </div>
            <div>
                <div class="stat-label">수거 필요 기기</div>
                <div class="stat-value">@_fullBins</div>
            </div>
        </div>
    </div>

    <div class="col-6 col-lg-3">
        <div class="stat-card">
            <div class="stat-icon icon-green">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="m12 2 9 4-9 4-9-4 9-4z" /><path d="m3 12 9 4 9-4" /><path d="m3 17 9 4 9-4" />
                </svg>
            </div>
            <div>
                <div class="stat-label">오늘 총 수거량</div>
                <div class="stat-value">@_totalCollectedKg.ToString("N0") <span class="unit">kg</span></div>
            </div>
        </div>
    </div>

    <div class="col-6 col-lg-3">
        <div class="stat-card">
            <div class="stat-icon icon-sky">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10" /><path d="M12 16v-4" /><path d="M12 8h.01" />
                </svg>
            </div>
            <div>
                <div class="stat-label">평균 적재 효율</div>
                <div class="stat-value">@_avgFillLevel<span class="unit">%</span></div>
            </div>
        </div>
    </div>
</div>

@code {
    private int _totalBins;
    private int _fullBins;
    private int _avgFillLevel;
    private int _totalCollectedKg;

    protected override async Task OnInitializedAsync()
    {
        var statsTask = BinService.GetStatsAsync();
        var collectedTask = TruckService.GetTotalCollectedKgAsync();
        await Task.WhenAll(statsTask, collectedTask);

        (_totalBins, _fullBins, _avgFillLevel) = statsTask.Result;
        _totalCollectedKg = collectedTask.Result;
    }
}
