@page "/trucks/{Code}"
@rendermode InteractiveServer
@implements IDisposable
@inject SmartBin.Services.TruckService TruckService

<PageTitle>@(_truck?.DisplayName ?? Code)</PageTitle>

<div class="d-flex align-items-center gap-2 mb-3">
    <a href="trucks" class="back-link">← 목록</a>
    <h1 class="m-0">@(_truck?.DisplayName ?? Code) 상세보기</h1>
    @if (_truck is not null)
    {
        <span class="status @_truck.StatusClass ms-2">@_truck.StatusText</span>
    }
    <button class="btn-primary-soft ms-auto" @onclick="ManualRefreshAsync" disabled="@_refreshing">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="23 4 23 10 17 10" />
            <polyline points="1 20 1 14 7 14" />
            <path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15" />
        </svg>
        @(_refreshing ? "불러오는 중..." : "새로고침")
    </button>
</div>

@if (_loading)
{
    <p>불러오는 중...</p>
}
else if (_truck is null)
{
    <p>해당 수거차를 찾을 수 없습니다.</p>
}
else
{
    <div class="row g-3 mb-3">
        <div class="col-6 col-md-3">
            <div class="stat-card">
                <div class="stat-icon icon-blue">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M1 7h13v10H1z" /><path d="M14 10h4l3 3v4h-7z" />
                        <circle cx="5.5" cy="18.5" r="2" /><circle cx="17.5" cy="18.5" r="2" />
                    </svg>
                </div>
                <div>
                    <div class="stat-label">현재 적재량</div>
                    <div class="stat-value">@_truck.LoadPercent<span class="unit">%</span></div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="stat-card">
                <div class="stat-icon icon-green">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M3 6h18" /><path d="M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2" />
                        <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6" />
                    </svg>
                </div>
                <div>
                    <div class="stat-label">현재 수거량</div>
                    <div class="stat-value">@(_truck.CollectedCount * 50)<span class="unit">kg</span></div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="stat-card">
                <div class="stat-icon icon-red">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M12 2L2 7l10 5 10-5-10-5z" /><path d="M2 17l10 5 10-5" /><path d="M2 12l10 5 10-5" />
                    </svg>
                </div>
                <div>
                    <div class="stat-label">수거 횟수</div>
                    <div class="stat-value">@TruckService.GetTripCount(_truck.TruckId)<span class="unit">회</span></div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="stat-card">
                <div class="stat-icon icon-sky">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 1 1 18 0z" />
                        <circle cx="12" cy="10" r="3" />
                    </svg>
                </div>
                <div>
                    <div class="stat-label">현재 목적지</div>
                    <div class="stat-value" style="font-size:1.1rem">@(string.IsNullOrEmpty(_truck.Destination) ? "—" : _truck.Destination)</div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-12 col-lg-5">
            <div class="panel">
                <h2 class="panel-title">기본 정보</h2>
                <dl class="info-list">
                    <dt>차량 ID</dt><dd>@_truck.TruckId</dd>
                    <dt>상태</dt><dd>@_truck.StatusText</dd>
                    <dt>최대 적재</dt><dd>@(_truck.MaxLoad * 50) kg</dd>
                    <dt>현재 수거량</dt><dd>@(_truck.CollectedCount * 50) kg</dd>
                    <dt>위치</dt><dd>X: @_truck.X.ToString("F2") / Y: @_truck.Y.ToString("F2") / Z: @_truck.Z.ToString("F2")</dd>
                    <dt>마지막 업데이트</dt><dd>@_truck.UpdatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</dd>
                </dl>
            </div>
        </div>
        <div class="col-12 col-lg-7">
            <div class="panel">
                <h2 class="panel-title">수거차 시뮬레이션</h2>
                <div id="sim-anchor" data-bin="@(-_truck.TruckIndex - 1)"
                     style="width:100%; height:560px; border-radius:8px; overflow:hidden; background:#0b1220; position:relative;">
                    <div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;color:rgba(255,255,255,0.3);font-size:0.9rem;pointer-events:none;">
                        시뮬레이션 로딩 중...
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string Code { get; set; } = "";

    private SmartBin.Models.Truck? _truck;
    private bool _loading = true;
    private bool _refreshing = false;
    private readonly CancellationTokenSource _cts = new();

    protected override async Task OnInitializedAsync()
    {
        _truck = await TruckService.GetByIdAsync(Code);
        _loading = false;
        _ = RunAutoRefreshAsync();
    }

    private async Task RunAutoRefreshAsync()
    {
        using var timer = new PeriodicTimer(TimeSpan.FromSeconds(5));
        try
        {
            while (await timer.WaitForNextTickAsync(_cts.Token))
            {
                _truck = await TruckService.GetByIdAsync(Code);
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException) { }
    }

    private async Task ManualRefreshAsync()
    {
        _refreshing = true;
        _truck = await TruckService.GetByIdAsync(Code);
        _refreshing = false;
    }

    public void Dispose()
    {
        _cts.Cancel();
        _cts.Dispose();
    }
}
