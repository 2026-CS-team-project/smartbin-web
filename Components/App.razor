<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <link rel="stylesheet" href="bootstrap/bootstrap.min.css" />
    <link rel="stylesheet" href="app.css" />
    <link rel="stylesheet" href="SmartBin.styles.css" />
    <link rel="icon" type="image/jpeg" href="SmartBin_icon.jpeg" />
    <HeadOutlet />
</head>

<body>
    <Routes />
    <!--
        sim-frame-host is declared here — in App.razor, the static HTML shell that the
        server renders for every page request. Blazor's enhanced navigation morphing
        algorithm (idiomorph) sees this element in BOTH the old DOM and every new HTML
        response, so it patches (preserves) it in-place instead of removing it.
        That means the Unity WebGL iframe is never recreated across navigations or
        SignalR reconnections, so the simulation never resets.
    -->
    <div id="sim-frame-host"
         style="position:fixed;top:0;left:0;width:100%;height:100%;visibility:visible;pointer-events:none;z-index:-1;">
        <iframe src="/webgl/index.html"
                title="SmartBin Simulation"
                allow="fullscreen"
                scrolling="no"
                style="width:100%;height:100%;border:0;display:block;background:#0b1220;"></iframe>
    </div>
    <script src="_framework/blazor.web.js"></script>
    <script src="js/persistentSim.js"></script>
</body>

</html>
