                new("BIN-007", "강남구 역삼동 은행사거리", 74, "주의",    "warn"),
                new("BIN-012", "강남구 논현동 학동역",     38, "정상",    "ok"),
            }),
        ["T-02"] = new("T-02", "이서연", "강남 2권역", "서울 34나 7890", "기아 봉고3", 3500, 88, 24, "차고지", "약 15분", "복귀중", "warn",
            new() {
                new("BIN-005", "강남구 대치동 대치사거리", 62, "정상",    "ok"),
                new("BIN-009", "강남구 삼성동 코엑스 앞",  45, "정상",    "ok"),
