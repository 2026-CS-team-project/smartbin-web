@page "/trucks"
@rendermode InteractiveServer
@inject SmartBin.Services.TruckService TruckService

<PageTitle>수거차 관리</PageTitle>

<div class="page-header">
    <h1 class="page-title">수거차 관리</h1>
    <div class="page-actions">
        <button class="btn-primary-soft" @onclick="RefreshAsync" disabled="@_refreshing">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="23 4 23 10 17 10" />
                <polyline points="1 20 1 14 7 14" />
                <path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15" />
            </svg>
            @(_refreshing ? "불러오는 중..." : "새로고침")
        </button>
    </div>
</div>

@if (_loading)
{
    <p>불러오는 중...</p>
}
else
{
    <div class="row g-3">
        @foreach (var truck in _trucks)
        {
            <div class="col-12 col-sm-6 col-lg-4 col-xl-3">
                <a class="bin-card" href="trucks/@truck.TruckId">
                    <div class="bin-card-header">
                        <span class="bin-id">@truck.TruckId</span>
                        <span class="status @truck.StatusClass">@truck.StatusText</span>
                    </div>
                    <div class="bin-name">@truck.DisplayName</div>
                    <div class="bin-meta">X: @truck.X.ToString("F1") / Y: @truck.Y.ToString("F1") / Z: @truck.Z.ToString("F1")</div>
                    <div class="fill-bar">
                        <div class="fill" style="width:@(truck.LoadPercent)%"></div>
                    </div>
                    <div class="bin-meta">적재 @truck.LoadPercent% · 수거 횟수 @TruckService.GetTripCount(truck.TruckId)회 · 현재 @(truck.CollectedCount * 50)kg</div>
                </a>
            </div>
        }
    </div>
}

@code {
    private List<SmartBin.Models.Truck> _trucks = new();
    private bool _loading = true;
    private bool _refreshing = false;

    protected override async Task OnInitializedAsync()
    {
        _trucks = await TruckService.GetAllAsync();
        _loading = false;
    }

    private async Task RefreshAsync()
    {
        _refreshing = true;
        _trucks = await TruckService.GetAllAsync();
        _refreshing = false;
    }
}
