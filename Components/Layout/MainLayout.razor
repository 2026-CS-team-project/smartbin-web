@inherits LayoutComponentBase

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="sim-frame-host"
     style="position:fixed; left:-99999px; top:0; width:1280px; height:800px; visibility:hidden; pointer-events:none; z-index:-1;">
    <iframe src="/webgl/index.html"
            title="SmartBin Simulation"
            allow="fullscreen"
            scrolling="no"
            style="width:100%; height:100%; border:0; display:block; background:#0b1220;"></iframe>
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>
