@page "/bins/{Id}"
@rendermode InteractiveServer
@inject SmartBin.Services.BinService BinService

<PageTitle>@(_bin?.DisplayName ?? Id)</PageTitle>

<div class="d-flex align-items-center gap-2 mb-3">
    <a href="bins" class="back-link">← 목록</a>
    <h1 class="m-0">@(_bin?.DisplayName ?? Id) 상세보기</h1>
    <button class="btn-primary-soft ms-auto" @onclick="RefreshAsync" disabled="@_refreshing">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="23 4 23 10 17 10" />
            <polyline points="1 20 1 14 7 14" />
            <path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15" />
        </svg>
        @(_refreshing ? "불러오는 중..." : "새로고침")
    </button>
</div>

@if (_loading)
{
    <p>불러오는 중...</p>
}
else if (_bin is null)
{
    <p>해당 쓰레기통을 찾을 수 없습니다.</p>
}
else
{
    <div class="row g-3 mb-3">
        <div class="col-6 col-md-3">
            <div class="stat-card">
                <div class="stat-label">현재 적재 상태</div>
                <div class="stat-value">
                    <span class="status @_bin.StatusClass">@_bin.StatusText</span>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="stat-card">
                <div class="stat-label">적재율</div>
                <div class="stat-value">@(_bin.DisplayFillLevel)<span class="unit">%</span></div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="stat-card">
                <div class="stat-label">X 좌표</div>
                <div class="stat-value">@_bin.X.ToString("F2")</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="stat-card">
                <div class="stat-label">Z 좌표</div>
                <div class="stat-value">@_bin.Z.ToString("F2")</div>
            </div>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-12 col-lg-7">
            <div class="panel">
                <h2 class="panel-title">상세 시뮬레이션</h2>
                <div id="sim-anchor" data-bin="@BinNumber"
                     style="width:100%; height:560px; border-radius:8px; overflow:hidden; background:#0b1220; position:relative;">
                    <div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;color:rgba(255,255,255,0.3);font-size:0.9rem;pointer-events:none;">
                        시뮬레이션 로딩 중...
                    </div>
                </div>
            </div>
        </div>
        <div class="col-12 col-lg-5">
            <div class="panel">
                <h2 class="panel-title">쓰레기통 정보</h2>
                <dl class="info-list">
                    <dt>쓰레기통 ID</dt><dd>@_bin.BinId</dd>
                    <dt>이름</dt><dd>@_bin.binName</dd>
                    <dt>위치</dt><dd>X: @_bin.X.ToString("F2") / Y: @_bin.Y.ToString("F2") / Z: @_bin.Z.ToString("F2")</dd>
                    <dt>적재율</dt><dd>@(_bin.DisplayFillLevel)%</dd>
                    <dt>적재 상태</dt><dd>@_bin.StatusText</dd>
                    <dt>마지막 업데이트</dt><dd>@_bin.UpdatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</dd>
                </dl>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string Id { get; set; } = "";

    private SmartBin.Models.Bin? _bin;
    private bool _loading = true;
    private bool _refreshing = false;

    private string BinNumber
    {
        get
        {
            var match = System.Text.RegularExpressions.Regex.Match(
                _bin?.binName ?? _bin?.BinId ?? Id, @"(\d+)\s*$");
            return match.Success ? match.Groups[1].Value : "0";
        }
    }

    protected override async Task OnInitializedAsync()
    {
        _bin = await BinService.GetByIdAsync(Id);
        _loading = false;
    }

    private async Task RefreshAsync()
    {
        _refreshing = true;
        _bin = await BinService.GetByIdAsync(Id);
        _refreshing = false;
    }
}
